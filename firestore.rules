rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: products
    // Document ID: string (e.g., obsidian-rose)
    // Fields:
    //   - id: string (required)
    //   - name: string (required)
    //   - notes: string (required)
    //   - price: number (required, positive)
    //   - img: string (required, URL)
    //   - gender: string (required, enum)
    //   - collection: string (required, enum)
    //   - description: string (required)
    //   - stock: number (required, >= 0)
    //   - createdAt: timestamp (optional, immutable)
    //
    // Collection: users
    // Document ID: user uid
    // Fields:
    //   - email: string (required)
    //   - role: string (required, 'admin' or 'customer')
    //   - firstName: string (optional)
    //   - lastName: string (optional)
    //   - country: string (optional)
    //   - province: string (optional)
    //   - city: string (optional)
    //   - address: string (optional)
    //   - postalCode: string (optional)
    //   - phone: string (optional)
    //   - notes: string (optional)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (
          (exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
           get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin') ||
          (request.auth.token.email == "msqureshi271@gmail.com" && request.auth.token.email_verified == true)
        );
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function isValidUrl(url) {
      return url is string && (url.matches("^https://.*") || url.matches("^http://.*"));
    }

    function isPositive(field) {
      return request.resource.data[field] is number && request.resource.data[field] > 0;
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================
    function isValidProduct() {
      let requiredFields = ['id', 'name', 'notes', 'price', 'img', 'gender', 'collection', 'description', 'stock'];
      let allowedFields = ['id', 'name', 'notes', 'price', 'img', 'color', 'gender', 'collection', 'description', 'stock', 'createdAt'];
      
      return hasRequiredFields(requiredFields) &&
             hasOnlyAllowedFields(allowedFields) &&
             request.resource.data.id is string && request.resource.data.id.size() > 0 && request.resource.data.id.size() < 100 &&
             request.resource.data.name is string && request.resource.data.name.size() > 0 && request.resource.data.name.size() < 100 &&
             request.resource.data.notes is string && request.resource.data.notes.size() > 0 && request.resource.data.notes.size() < 200 &&
             isPositive('price') &&
             request.resource.data.stock is number && request.resource.data.stock >= 0 &&
             isValidUrl(request.resource.data.img) && request.resource.data.img.size() < 1000 &&
             (!('color' in request.resource.data) || (request.resource.data.color is string && request.resource.data.color.size() <= 20)) &&
             request.resource.data.gender in ['Unisex', 'Feminine', 'Masculine'] &&
             request.resource.data.collection in ['Permanent', 'Private Blend', 'Limited'] &&
             request.resource.data.description is string && request.resource.data.description.size() > 0 && request.resource.data.description.size() < 2000;
    }

    function isValidUser() {
      let requiredFields = ['email', 'role'];
      let allowedFields = ['email', 'role', 'firstName', 'lastName', 'country', 'province', 'city', 'address', 'postalCode', 'phone', 'notes'];
      
      return hasRequiredFields(requiredFields) &&
             hasOnlyAllowedFields(allowedFields) &&
             request.resource.data.email is string && request.resource.data.email.size() < 200 &&
             request.resource.data.role in ['admin', 'customer'] &&
             (!('firstName' in request.resource.data) || (request.resource.data.firstName is string && request.resource.data.firstName.size() < 100)) &&
             (!('lastName' in request.resource.data) || (request.resource.data.lastName is string && request.resource.data.lastName.size() < 100)) &&
             (!('country' in request.resource.data) || (request.resource.data.country is string && request.resource.data.country.size() < 100)) &&
             (!('province' in request.resource.data) || (request.resource.data.province is string && request.resource.data.province.size() < 100)) &&
             (!('city' in request.resource.data) || (request.resource.data.city is string && request.resource.data.city.size() < 100)) &&
             (!('address' in request.resource.data) || (request.resource.data.address is string && request.resource.data.address.size() < 500)) &&
             (!('postalCode' in request.resource.data) || (request.resource.data.postalCode is string && request.resource.data.postalCode.size() < 50)) &&
             (!('phone' in request.resource.data) || (request.resource.data.phone is string && request.resource.data.phone.size() < 50)) &&
             (!('notes' in request.resource.data) || (request.resource.data.notes is string && request.resource.data.notes.size() < 1000));
    }

    function isValidOrder() {
      let requiredFields = ['userId', 'items', 'totalAmount', 'status', 'createdAt', 'userEmail'];
      let allowedFields = ['userId', 'items', 'totalAmount', 'status', 'createdAt', 'shippingAddress', 'userEmail'];
      
      return hasRequiredFields(requiredFields) &&
             hasOnlyAllowedFields(allowedFields) &&
             request.resource.data.userId is string && request.resource.data.userId == request.auth.uid &&
             request.resource.data.userEmail is string &&
             request.resource.data.items is list && request.resource.data.items.size() > 0 && request.resource.data.items.size() <= 100 &&
             isPositive('totalAmount') &&
             request.resource.data.status in ['Pending', 'Accepted', 'Rejected', 'Dispatched', 'Delivered'] &&
             (!('shippingAddress' in request.resource.data) || request.resource.data.shippingAddress is map);
    }

    // ===============================================================
    // Rules
    // ===============================================================
    
    match /{path=**}/orders/{orderId} {
      allow read: if isAdmin();
    }

    match /products/{productId} {
      // Anyone can read products
      allow read: if true;
      // Only admins can create/delete products
      allow create: if isAdmin() && isValidProduct();
      allow delete: if isAdmin();
      // Admins can update anything, users can only decrement stock
      allow update: if (isAdmin() && isValidProduct() && (!('createdAt' in request.resource.data) || request.resource.data.createdAt == resource.data.createdAt)) ||
                    (isAuthenticated() && 
                     request.resource.data.diff(resource.data).affectedKeys().hasOnly(['stock']) &&
                     request.resource.data.stock < resource.data.stock &&
                     request.resource.data.stock >= 0);
    }

    match /users/{userId} {
      // Users can read their own profile, admins can read all
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      // Users can create their own profile as 'customer', admins can create any
      allow create: if isAuthenticated() && isValidUser() && 
                    ((request.auth.uid == userId && request.resource.data.role == 'customer') || isAdmin());
      // Users can update their own profile but cannot change their role, admins can update any
      allow update: if isAuthenticated() && isValidUser() && 
                    ((request.auth.uid == userId && request.resource.data.role == resource.data.role) || isAdmin());
      allow delete: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      
      match /orders/{orderId} {
        // Users can read their own orders, admins can read all
        allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
        // Users can create their own orders
        allow create: if isAuthenticated() && request.auth.uid == userId && isValidOrder();
        // Admins can update order status
        allow update: if isAdmin() &&
                      request.resource.data.userId == resource.data.userId &&
                      request.resource.data.items == resource.data.items &&
                      request.resource.data.totalAmount == resource.data.totalAmount &&
                      request.resource.data.createdAt == resource.data.createdAt;
        // Users can delete their own orders, admins can delete any
        allow delete: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      }
    }
  }
}
